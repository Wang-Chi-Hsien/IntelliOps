<Window x:Class="IntelliOps.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IntelliOps Command Center" Height="650" Width="1000"
        Background="#1E1E1E" Foreground="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="10">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="🔴 LIVE EVENTS" FontWeight="Bold" Foreground="#FF5555" VerticalAlignment="Center"/>

                    <Button Name="BtnResumeScroll" Content="▶ Resume Live" 
                            Background="#007ACC" Foreground="White" BorderThickness="0"
                            Padding="10,5" HorizontalAlignment="Right" Cursor="Hand"
                            Visibility="Collapsed" Click="BtnResumeScroll_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <ListView Name="LogListView" Background="Transparent" BorderThickness="0" Foreground="#DDD" 
                          SelectionChanged="LogListView_SelectionChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252526" CornerRadius="6" Margin="0,3,5,3" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Width="24" Height="24" Margin="0,0,12,0" VerticalAlignment="Top">

                                        <Grid x:Name="IconError" Visibility="Collapsed">
                                            <Ellipse Fill="#FF5252"/>
                                            <Path Data="M18,6L16.6,4.6L12,9.2L7.4,4.6L6,6L10.6,10.6L6,15.2L7.4,16.6L12,12L16.6,16.6L18,15.2L13.4,10.6z" 
                                                  Fill="White" Stretch="Uniform" Margin="6"/>
                                        </Grid>

                                        <Grid x:Name="IconWarning" Visibility="Collapsed">
                                            <Path Data="M12,2 L1,21 H23 L12,2 Z" Fill="#FFC107" Stretch="Uniform"/>
                                            <Path Data="M11,15 V17 H13 V15 Z M11,8 V13 H13 V8 Z" Fill="#252526" Stretch="Uniform" Margin="10,6,10,4"/>
                                        </Grid>

                                        <Grid x:Name="IconInfo" Visibility="Collapsed">
                                            <Ellipse Fill="#555"/>
                                            <TextBlock Text="i" Foreground="White" FontWeight="Bold" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding Source}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="{Binding DisplayTime}" DockPanel.Dock="Right" Foreground="#888" FontSize="11" VerticalAlignment="Bottom"/>
                                        </DockPanel>

                                        <TextBlock Text="{Binding Message}" 
                                                   Foreground="#BBB" FontSize="12" Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxHeight="36" 
                                                   ToolTip="{Binding Message}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding LogType}" Value="Error">
                                    <Setter TargetName="IconError" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="IconWarning" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="IconInfo" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LogType}" Value="Warning">
                                    <Setter TargetName="IconError" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="IconWarning" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="IconInfo" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="KNOWLEDGE BASE MATCH" FontSize="11" FontWeight="Bold" Foreground="#4EC9B0"/>
                        <TextBlock Name="TxtRagScore" Text="Similarity: --%" HorizontalAlignment="Right" Foreground="Yellow"/>
                    </DockPanel>
                    <TextBlock Name="TxtRagContent" Text="Select a log to investigate..." TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#EEE"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#252526" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="INTELLIGENT ANALYSIS" FontSize="11" FontWeight="Bold" Foreground="#007ACC"/>

                    <TextBox Grid.Row="1" Name="TxtAiAnalysis" Background="Transparent" Foreground="#DDD" 
                             BorderThickness="0" TextWrapping="Wrap" Margin="0,10,0,0" IsReadOnly="True"
                             Text=""/>

                    <StackPanel Name="LoadingPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="AI Analyst is thinking..." Foreground="#007ACC" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" BorderThickness="0" Background="#333" Foreground="#007ACC"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                <TextBlock Text="RECOMMENDED ACTIONS" FontSize="11" FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,10"/>
                <ItemsControl Name="ActionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="0,0,10,0" Padding="15,10" 
                                    Background="#333" Foreground="White" FontWeight="Bold"
                                    Click="ActionButton_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#555" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Grid>
</Window>